# Normalise line endings automatically based on git's heuristics
* text=auto

# Force LF on source files — keeps generated archives and editor diffs sane
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf

# Binaries — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.tgz binary
